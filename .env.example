# Public values safe for the browser. Get these from Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Server-only: never expose this value to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_key

# Server-only password required before sending sign-in links and activating the first owner.
LOFTY_MASTER_LOGIN_PASSWORD=replace-with-a-long-random-password

# Shared server-to-server secret used by the main Lofty Studios website.
# Send it in the x-lofty-ingest-secret header when calling POST /api/leads.
LOFTY_LEAD_INGEST_SECRET=replace-with-a-long-random-secret
